# ============================================================
# .gitignore — NIMO
# No modificar sin revisar primero qué se está ignorando.
# ============================================================

# ----- Dependencias -----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Testing -----
/coverage

# ----- Next.js build -----
/.next/
/out/
/build

# ----- Variables de entorno (NUNCA al repo) -----
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example SÍ va al repo (contiene plantilla sin valores reales)
!.env.example

# ----- Credenciales y datos sensibles -----
credentials.md
*.pem
*.key
*.cert

# ----- Misc sistema operativo -----
.DS_Store
Thumbs.db

# ----- Logs -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- Vercel -----
.vercel

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- PDFs generados localmente -----
/public/pdfs/

# Migraciones SQL: viven en ../.docs/migrations (fuera del repo)
supabase/
