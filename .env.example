# ============================================================
# Archivo: .env.example
# Ruta: /nimo/nimo/.env.example
# Creado: 2026-06-06
# Descripción: Plantilla de variables de entorno para NIMO.
#              Copiar como .env.local y completar los valores.
#              NUNCA commitear .env.local — está en .gitignore.
# ============================================================

# ----- Supabase -----
# URL del proyecto Supabase (visible en el dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública (anon). Puede exponerse al cliente — solo tiene permisos definidos por RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (service_role). SOLO en el servidor. JAMÁS en código cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ID del proyecto (para CLI: supabase gen types)
SUPABASE_PROJECT_ID=

# ----- App -----
# URL base de la app. En desarrollo: http://localhost:3000. En producción: https://nimo.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dominio de producción (para construir URLs absolutas de tenants)
NEXT_PUBLIC_APP_DOMAIN=nimo.app

# URL de la landing de NIMO (el link "Sitio web por NIMO" del footer de cada agencia).
# Si no se setea, usa NEXT_PUBLIC_APP_URL. Cuando NIMO tenga su .com propio, cambiar acá.
NEXT_PUBLIC_NIMO_URL=https://nimo-crm.vercel.app

# ----- Email (Resend) -----
# API key de Resend. Obtener en resend.com/api-keys
RESEND_API_KEY=

# Dirección de email desde la que se envían los correos de la plataforma
RESEND_FROM_EMAIL=noreply@nimo.app

# ----- WhatsApp Cloud API (Fase 2/3 — dejar vacío en Fase 1) -----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ----- LLM / IA (Fase 3 — dejar vacío en Fase 1) -----
# OpenRouter permite usar múltiples modelos con una sola key
OPENROUTER_API_KEY=

# Keys directas (opcionales si usás OpenRouter como gateway)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ----- Seguridad -----
# Secret para proteger los endpoints /api/cron/* contra llamadas externas
CRON_SECRET=

# Email del super-admin de la plataforma (dueño de NIMO). Solo este email puede acceder a /superadmin.
SUPER_ADMIN_EMAIL=

# ----- Sentry (Observabilidad — opcional) -----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
